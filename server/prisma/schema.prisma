// filepath: server/prisma/schema.prisma
// PostgreSQL Schema for Suivi Sportif

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== Enums ==============

enum ExerciseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ExerciseType {
  STRENGTH
  CARDIO
  MOBILITY
}

enum MuscleRole {
  PRIMARY
  SECONDARY
}

enum ExerciseMediaType {
  IMAGE
  VIDEO
  GIF
}

// ============== User Model ==============

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  foods          Food[]
  meals          Meal[]
  nutritionGoals NutritionGoal[]
  workouts       Workout[]

  @@map("users")
}

// ============== Exercise Model ==============

model Exercise {
  id           String              @id @default(uuid())
  name         String
  description  String?             @db.Text
  difficulty   ExerciseDifficulty  @default(BEGINNER)
  exerciseType ExerciseType        @default(STRENGTH) @map("exercise_type")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  workoutExercises WorkoutExercise[]

  categories   ExerciseCategoryOnExercise[]
  muscles      ExerciseMuscle[]
  equipment    ExerciseEquipment[]
  instructions ExerciseInstruction[]
  media        ExerciseMedia[]

  @@index([name])
  @@index([difficulty])
  @@index([exerciseType])
  @@map("exercises")
}

// ============== Exercise Category Model ==============

model ExerciseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exercises ExerciseCategoryOnExercise[]

  @@map("exercise_categories")
}

// ============== Exercise <-> Category Junction ==============

model ExerciseCategoryOnExercise {
  exerciseId String @map("exercise_id")
  categoryId String @map("category_id")

  exercise Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  category ExerciseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([exerciseId, categoryId])
  @@index([categoryId])
  @@map("exercise_category_on_exercise")
}

// ============== Muscle Model ==============

model Muscle {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exercises ExerciseMuscle[]

  @@map("muscles")
}

// ============== Exercise <-> Muscle Junction ==============

model ExerciseMuscle {
  exerciseId String     @map("exercise_id")
  muscleId   String     @map("muscle_id")
  role       MuscleRole @default(PRIMARY)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id], onDelete: Cascade)

  @@id([exerciseId, muscleId])
  @@index([muscleId])
  @@index([role])
  @@map("exercise_muscles")
}

// ============== Equipment Model ==============

model Equipment {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exercises ExerciseEquipment[]

  @@map("equipment")
}

// ============== Exercise <-> Equipment Junction ==============

model ExerciseEquipment {
  exerciseId  String @map("exercise_id")
  equipmentId String @map("equipment_id")

  exercise  Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([exerciseId, equipmentId])
  @@index([equipmentId])
  @@map("exercise_equipment")
}

// ============== Exercise Instruction Model ==============

model ExerciseInstruction {
  id          String   @id @default(uuid())
  exerciseId  String   @map("exercise_id")
  stepOrder   Int      @map("step_order")
  instruction String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([exerciseId, stepOrder])
  @@index([exerciseId])
  @@map("exercise_instructions")
}

// ============== Exercise Media Model ==============

model ExerciseMedia {
  id         String            @id @default(uuid())
  exerciseId String            @map("exercise_id")
  mediaType  ExerciseMediaType @map("media_type")
  url        String            @db.Text
  isMain     Boolean           @default(false) @map("is_main")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([mediaType])
  @@map("exercise_media")
}

// ============== Workout Model ==============

model Workout {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  date      DateTime
  duration  Int // en minutes
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]

  @@index([userId, date])
  @@map("workouts")
}

// ============== WorkoutExercise Model (junction) ==============

model WorkoutExercise {
  id         String @id @default(uuid())
  workoutId  String @map("workout_id")
  exerciseId String @map("exercise_id")
  order      Int    @default(0)

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  sets WorkoutSet[]

  @@unique([workoutId, exerciseId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

// ============== WorkoutSet Model ==============

model WorkoutSet {
  id                String   @id @default(uuid())
  workoutExerciseId String   @map("workout_exercise_id")
  setNumber         Int      @map("set_number")
  reps              Int
  weight            Decimal  @db.Decimal(10, 2)
  rest              Int      @default(60) // en secondes
  createdAt         DateTime @default(now()) @map("created_at")

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
  @@map("workout_sets")
}

// ============== Food Model ==============

model Food {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  name         String
  brand        String?
  barcode      String?
  caloriesKcal Decimal  @map("calories_kcal") @db.Decimal(10, 2)
  proteinGrams Decimal  @map("protein_grams") @db.Decimal(10, 2)
  carbsGrams   Decimal  @map("carbs_grams") @db.Decimal(10, 2)
  fatGrams     Decimal  @map("fat_grams") @db.Decimal(10, 2)
  fiberGrams   Decimal? @map("fiber_grams") @db.Decimal(10, 2)
  servingUnit  String   @default("g") @map("serving_unit")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItems MealItem[]

  @@index([userId, name])
  @@index([barcode])
  @@map("foods")
}

// ============== Meal Model ==============

model Meal {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  date      DateTime
  mealType  String   @default("other") @map("meal_type")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealItem[]

  @@index([userId, date])
  @@index([userId, mealType])
  @@map("meals")
}

// ============== MealItem Model ==============

model MealItem {
  id                  String   @id @default(uuid())
  mealId              String   @map("meal_id")
  foodId              String?  @map("food_id")
  foodName            String   @map("food_name")
  quantityGrams       Decimal  @map("quantity_grams") @db.Decimal(10, 2)
  caloriesKcalPer100g Decimal  @map("calories_kcal_per_100g") @db.Decimal(10, 2)
  proteinGramsPer100g Decimal  @map("protein_grams_per_100g") @db.Decimal(10, 2)
  carbsGramsPer100g   Decimal  @map("carbs_grams_per_100g") @db.Decimal(10, 2)
  fatGramsPer100g     Decimal  @map("fat_grams_per_100g") @db.Decimal(10, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  meal Meal  @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food? @relation(fields: [foodId], references: [id], onDelete: SetNull)

  @@index([mealId])
  @@index([foodId])
  @@map("meal_items")
}

// ============== NutritionGoal Model ==============

model NutritionGoal {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  name              String
  startDate         DateTime  @map("start_date")
  endDate           DateTime? @map("end_date")
  dailyCaloriesKcal Int       @map("daily_calories_kcal")
  dailyProteinGrams Decimal?  @map("daily_protein_grams") @db.Decimal(10, 2)
  dailyCarbsGrams   Decimal?  @map("daily_carbs_grams") @db.Decimal(10, 2)
  dailyFatGrams     Decimal?  @map("daily_fat_grams") @db.Decimal(10, 2)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, startDate])
  @@map("nutrition_goals")
}

// Note: Prisma uses Decimal for precise numeric values
// In the application, convert to number for calculations